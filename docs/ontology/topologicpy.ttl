@prefix bot: <https://w3id.org/bot#> .
@prefix brick: <https://brickschema.org/schema/Brick#> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix ifc: <https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix top: <http://w3id.org/topologicpy#> .
@prefix dict: <http://w3id.org/topologicpy/dictionary#> .
@prefix inst: <http://w3id.org/topologicpy/instance#> .

top:TopologicPyOntology rdf:type owl:Ontology .
top:TopologicPyOntology rdfs:label "TopologicPy Ontology" .
top:TopologicPyOntology rdfs:comment "A compact OWL/RDFS vocabulary for TopologicPy topology, graph, BIM/IFC/BOT/Brick alignment, dictionary metadata, graph metadata, provenance, and analysis results." .
top:AccessGraph rdf:type owl:Class .
top:AccessGraph rdfs:label "AccessGraph" .
top:AccessGraph rdfs:comment "A directed or undirected graph used to represent permitted access between spaces, rooms, zones, portals, doors, apertures, circulation elements, or other traversable entities. Edges may encode passability, access control, traversal direction, door type, cost, distance, or movement constraints." .
top:AccessGraph rdfs:subClassOf top:SpatialGraph .
top:AdjacencyGraph rdf:type owl:Class .
top:AdjacencyGraph rdfs:label "AdjacencyGraph" .
top:AdjacencyGraph rdfs:comment "An undirected graph used to represent adjacency between topological, geometric, spatial, or semantic entities. Edges typically indicate that two entities touch, share a boundary, are incident, are proximal within a specified tolerance, or satisfy a declared adjacency predicate." .
top:AdjacencyGraph rdfs:subClassOf top:SpatialGraph .
top:AnalysisGraph rdf:type owl:Class .
top:AnalysisGraph rdfs:label "AnalysisGraph" .
top:AnalysisGraph rdfs:comment "A directed or undirected graph used to represent entities and relationships prepared for computational analysis. Vertices, edges, and graph-level dictionaries may encode analytical attributes, weights, labels, features, metrics, simulation values, or machine-learning inputs and outputs." .
top:AnalysisGraph rdfs:subClassOf top:Graph .
top:AnalysisMetric rdf:type owl:Class .
top:AnalysisMetric rdfs:label "AnalysisMetric" .
top:AnalysisMetric rdfs:comment "A computed metric associated with geometry, topology, graphs, buildings, systems, simulation, performance analysis, or machine-learning workflows." .
top:Aperture rdf:type owl:Class .
top:Aperture rdfs:label "Aperture" .
top:Aperture rdfs:comment "A topological or building-domain opening associated with a host topology or element. In TopologicPy it is treated as an aperture/opening construct and may be represented geometrically by a face-like boundary." .
top:Aperture rdfs:subClassOf top:Face .
top:Aperture rdfs:subClassOf top:Element .
top:Aperture rdfs:subClassOf bot:Element .
top:Attribute rdf:type owl:Class .
top:Attribute rdfs:label "Attribute" .
top:Attribute rdfs:comment "A semantic or analytical key-value attribute associated with a topology, graph, node, relationship, dataset, metric, or external entity." .
top:Beam rdf:type owl:Class .
top:Beam rdfs:label "Beam" .
top:Beam rdfs:comment "A beam, girder, or linear structural member." .
top:Beam rdfs:subClassOf top:Element .
top:Beam rdfs:subClassOf bot:Element .
top:Boundary rdf:type owl:Class .
top:Boundary rdfs:label "Boundary" .
top:Boundary rdfs:comment "A topology used to represent the boundary of another topology, spatial region, element, or analytical domain." .
top:Boundary rdfs:subClassOf top:Topology .
top:Building rdf:type owl:Class .
top:Building rdfs:label "Building" .
top:Building rdfs:comment "A building-level spatial container used to represent a whole building, facility, or IFC building." .
top:Building rdfs:subClassOf top:Zone .
top:Building rdfs:subClassOf bot:Building .
top:Cell rdf:type owl:Class .
top:Cell rdfs:label "Cell" .
top:Cell rdfs:comment "A three-dimensional TopologicPy topology bounded by faces or shells and representing a volumetric region." .
top:Cell rdfs:subClassOf top:Topology .
top:CellComplex rdf:type owl:Class .
top:CellComplex rdfs:label "CellComplex" .
top:CellComplex rdfs:comment "A TopologicPy topology composed of cells, typically with non-manifold adjacency through shared faces." .
top:CellComplex rdfs:subClassOf top:Topology .
top:CirculationGraph rdf:type owl:Class .
top:CirculationGraph rdfs:label "CirculationGraph" .
top:CirculationGraph rdfs:comment "A directed or undirected graph used to represent movement, circulation, or route-choice relationships among spaces, portals, corridors, stairs, entrances, exits, or waypoints. Edges may encode route length, cost, capacity, direction, or accessibility." .
top:CirculationGraph rdfs:subClassOf top:SpatialGraph .
top:CirculationZone rdf:type owl:Class .
top:CirculationZone rdfs:label "CirculationZone" .
top:CirculationZone rdfs:comment "A zone primarily used to represent movement, access, circulation, transition, or evacuation functions." .
top:CirculationZone rdfs:subClassOf top:Zone .
top:CirculationZone rdfs:subClassOf bot:Zone .
top:ClassificationReference rdf:type owl:Class .
top:ClassificationReference rdfs:label "ClassificationReference" .
top:ClassificationReference rdfs:comment "A classification reference used to represent external classification systems, codes, taxonomies, or IFC classification references." .
top:Cluster rdf:type owl:Class .
top:Cluster rdfs:label "Cluster" .
top:Cluster rdfs:comment "A heterogeneous TopologicPy topology used to group vertices, edges, wires, faces, shells, cells, cell complexes, or other clusters without requiring manifold connectivity." .
top:Cluster rdfs:subClassOf top:Topology .
top:Column rdf:type owl:Class .
top:Column rdfs:label "Column" .
top:Column rdfs:comment "A column or vertical structural member." .
top:Column rdfs:subClassOf top:Element .
top:Column rdfs:subClassOf bot:Element .
top:ConnectivityGraph rdf:type owl:Class .
top:ConnectivityGraph rdfs:label "ConnectivityGraph" .
top:ConnectivityGraph rdfs:comment "A directed or undirected graph used to represent generic connectivity or reachability among topological, spatial, building, system, or graph entities. Edges indicate that two entities are connected according to an explicit computational or semantic rule." .
top:ConnectivityGraph rdfs:subClassOf top:SpatialGraph .
top:Context rdf:type owl:Class .
top:Context rdfs:label "Context" .
top:Context rdfs:comment "A contextual reference used by TopologicPy to associate content with a host topology or subtopology." .
top:CurtainWall rdf:type owl:Class .
top:CurtainWall rdfs:label "CurtainWall" .
top:CurtainWall rdfs:comment "A curtain-wall element represented as a specialised wall or façade system." .
top:CurtainWall rdfs:subClassOf top:Wall .
top:CurtainWall rdfs:subClassOf bot:Element .
top:Dictionary rdf:type owl:Class .
top:Dictionary rdfs:label "Dictionary" .
top:Dictionary rdfs:comment "A key-value metadata container used by TopologicPy to attach semantic, analytical, geometric, provenance, and interoperability data to topologies, graphs, vertices, edges, and records." .
top:DirectedRelationship rdf:type owl:Class .
top:DirectedRelationship rdfs:label "DirectedRelationship" .
top:DirectedRelationship rdfs:comment "A directed graph relationship used to represent an ordered source-to-target relation between two nodes." .
top:DirectedRelationship rdfs:subClassOf top:Relationship .
top:Door rdf:type owl:Class .
top:Door rdfs:label "Door" .
top:Door rdfs:comment "A door, access, or operable passage element, commonly associated with openings, access graphs, and navigation relationships." .
top:Door rdfs:subClassOf top:Element .
top:Door rdfs:subClassOf bot:Element .
top:DualGraph rdf:type owl:Class .
top:DualGraph rdfs:label "DualGraph" .
top:DualGraph rdfs:comment "An undirected graph used to represent adjacency between higher-dimensional entities such as faces, cells, rooms, spaces, zones, or regions. Each entity is represented as a vertex, and an edge represents a shared boundary, interface, aperture, adjacency relation, or other declared connection between two entities." .
top:DualGraph rdfs:subClassOf top:SpatialGraph .
top:Edge rdf:type owl:Class .
top:Edge rdfs:label "Edge" .
top:Edge rdfs:comment "A one-dimensional TopologicPy topology connecting a start vertex to an end vertex." .
top:Edge rdfs:subClassOf top:Topology .
top:EdgeFeature rdf:type owl:Class .
top:EdgeFeature rdfs:label "EdgeFeature" .
top:EdgeFeature rdfs:comment "A numerical, categorical, vector, or encoded feature associated with a graph edge or relationship record." .
top:EdgeFeature rdfs:subClassOf top:Attribute .
top:Element rdf:type owl:Class .
top:Element rdfs:label "Element" .
top:Element rdfs:comment "A physical, conceptual, or analytical building/infrastructure element that may be represented by topology and aligned with BIM entities." .
top:Element rdfs:subClassOf top:Topology .
top:Element rdfs:subClassOf bot:Element .
top:Equipment rdf:type owl:Class .
top:Equipment rdfs:label "Equipment" .
top:Equipment rdfs:comment "A building, MEP, operational, or service equipment element, optionally aligned with Brick equipment classes when system semantics are available." .
top:Equipment rdfs:subClassOf top:Element .
top:Equipment rdfs:subClassOf brick:Equipment .
top:ExternalBoundary rdf:type owl:Class .
top:ExternalBoundary rdfs:label "ExternalBoundary" .
top:ExternalBoundary rdfs:comment "A boundary topology used to represent the outer boundary of another topology, region, element, or analytical domain." .
top:ExternalBoundary rdfs:subClassOf top:Boundary .
top:Face rdf:type owl:Class .
top:Face rdfs:label "Face" .
top:Face rdfs:comment "A two-dimensional TopologicPy topology bounded by an external wire and, optionally, one or more internal boundary wires." .
top:Face rdfs:subClassOf top:Topology .
top:FunctionalZone rdf:type owl:Class .
top:FunctionalZone rdfs:label "FunctionalZone" .
top:FunctionalZone rdfs:comment "A zone grouped by use, function, programme, activity, department, or other non-geometric classification." .
top:FunctionalZone rdfs:subClassOf top:Zone .
top:FunctionalZone rdfs:subClassOf bot:Zone .
top:Furniture rdf:type owl:Class .
top:Furniture rdfs:label "Furniture" .
top:Furniture rdfs:comment "A furniture or furnishing element." .
top:Furniture rdfs:subClassOf top:Element .
top:Furniture rdfs:subClassOf bot:Element .
top:Graph rdf:type owl:Class .
top:Graph rdfs:label "Graph" .
top:Graph rdfs:comment "A directed, undirected, mixed, weighted, unweighted, simple, or multigraph representation used to represent entities and relationships emitted, consumed, analysed, or transformed by TopologicPy. More specific graph semantics are defined by subclasses." .
top:GraphDataset rdf:type owl:Class .
top:GraphDataset rdfs:label "GraphDataset" .
top:GraphDataset rdfs:comment "A dataset used to represent graphs, nodes, edges, labels, masks, features, metadata, and ontology annotations for graph analysis or graph machine learning." .
top:GraphFeature rdf:type owl:Class .
top:GraphFeature rdfs:label "GraphFeature" .
top:GraphFeature rdfs:comment "A numerical, categorical, vector, or encoded feature associated with a graph-level record." .
top:GraphFeature rdfs:subClassOf top:Attribute .
top:Grid rdf:type owl:Class .
top:Grid rdfs:label "Grid" .
top:Grid rdfs:comment "A spatial subdivision, sampling, or reference structure used to generate or organise vertices, edges, cells, or analysis samples." .
top:HasseDiagramGraph rdf:type owl:Class .
top:HasseDiagramGraph rdfs:label "HasseDiagramGraph" .
top:HasseDiagramGraph rdfs:comment "A directed acyclic graph used to represent a partially ordered set, typically by showing only cover relations after transitive reduction. In TopologicPy, it may represent hierarchical containment, decomposition, incidence, or boundary relationships among topological entities." .
top:HasseDiagramGraph rdfs:subClassOf top:Graph .
top:Interface rdf:type owl:Class .
top:Interface rdfs:label "Interface" .
top:Interface rdfs:comment "A shared boundary or interface between spaces, zones, elements, or topologies, including IFC space-boundary-style relationships." .
top:Interface rdfs:subClassOf top:Face .
top:Interface rdfs:subClassOf bot:Interface .
top:InternalBoundary rdf:type owl:Class .
top:InternalBoundary rdfs:label "InternalBoundary" .
top:InternalBoundary rdfs:comment "A boundary topology used to represent a hole, void, inner loop, or internal boundary of another topology, region, element, or analytical domain." .
top:InternalBoundary rdfs:subClassOf top:Boundary .
top:Isovist rdf:type owl:Class .
top:Isovist rdfs:label "Isovist" .
top:Isovist rdfs:comment "A visibility field, polygon, volume, or related visual metric computed from an observation point or region." .
top:Isovist rdfs:subClassOf top:AnalysisMetric .
top:IsovistGraph rdf:type owl:Class .
top:IsovistGraph rdfs:label "IsovistGraph" .
top:IsovistGraph rdfs:comment "A directed or undirected spatial graph used to represent isovists, visibility fields, or relationships between observation points and visible spatial extents. Vertices may represent viewpoints, isovist polygons, spatial samples, or visible objects, while edges may encode visibility, overlap, containment, or intervisibility relationships." .
top:IsovistGraph rdfs:subClassOf top:SpatialGraph .
top:KnowledgeGraph rdf:type owl:Class .
top:KnowledgeGraph rdfs:label "KnowledgeGraph" .
top:KnowledgeGraph rdfs:comment "A directed semantic graph used to represent entities, attributes, relationships, and inferred knowledge. In TopologicPy, it may encode topological objects, BIM entities, ontology classes, RDF triples, rules, reasoning outputs, or links between geometry, topology, semantics, analysis, and external knowledge sources." .
top:KnowledgeGraph rdfs:subClassOf top:Graph .
top:LineGraph rdf:type owl:Class .
top:LineGraph rdfs:label "LineGraph" .
top:LineGraph rdfs:comment "An undirected or directed graph used to represent edge-to-edge relationships derived from another graph. Each vertex in the line graph represents an edge of the source graph, and each edge in the line graph represents adjacency, incidence, continuity, succession, or compatibility between source edges." .
top:LineGraph rdfs:subClassOf top:Graph .
top:Material rdf:type owl:Class .
top:Material rdfs:label "Material" .
top:Material rdfs:comment "A material record used to represent material identity, composition, assignment, or IFC material information." .
top:MaterialSet rdf:type owl:Class .
top:MaterialSet rdfs:label "MaterialSet" .
top:MaterialSet rdfs:comment "A material-set record used to represent material lists, material layer sets, material constituent sets, or other grouped material definitions." .
top:Matrix rdf:type owl:Class .
top:Matrix rdfs:label "Matrix" .
top:Matrix rdfs:comment "A numerical matrix used to represent transformations, coordinate operations, or other matrix-valued quantities." .
top:Member rdf:type owl:Class .
top:Member rdfs:label "Member" .
top:Member rdfs:comment "A generic structural, framing, or linear member when a more specific class such as Beam or Column is not asserted." .
top:Member rdfs:subClassOf top:Element .
top:Member rdfs:subClassOf bot:Element .
top:NavigationGraph rdf:type owl:Class .
top:NavigationGraph rdfs:label "NavigationGraph" .
top:NavigationGraph rdfs:comment "A directed or undirected weighted graph used to represent navigable movement through spaces, paths, portals, waypoints, circulation systems, or walkable regions. Edges typically encode traversability and may store distance, travel time, slope, accessibility, obstruction, cost, or agent-specific movement constraints." .
top:NavigationGraph rdfs:subClassOf top:SpatialGraph .
top:Node rdf:type owl:Class .
top:Node rdfs:label "Node" .
top:Node rdfs:comment "A graph node represented by, or projected from, a TopologicPy vertex or TGraph vertex record. Nodes may carry dictionary metadata, ontology class information, labels, features, coordinates, and external identifiers." .
top:Node rdfs:subClassOf top:Vertex .
top:NodeFeature rdf:type owl:Class .
top:NodeFeature rdfs:label "NodeFeature" .
top:NodeFeature rdfs:comment "A numerical, categorical, vector, or encoded feature associated with a graph node or vertex record." .
top:NodeFeature rdfs:subClassOf top:Attribute .
top:Opening rdf:type owl:Class .
top:Opening rdfs:label "Opening" .
top:Opening rdfs:comment "An opening element, void, recess, penetration, or host-element subtraction associated with doors, windows, services, or coordination checks." .
top:Opening rdfs:subClassOf top:Element .
top:Opening rdfs:subClassOf bot:Element .
top:Path rdf:type owl:Class .
top:Path rdfs:label "Path" .
top:Path rdfs:comment "An ordered graph structure used to represent a sequence of nodes and relationships, typically returned by routing, shortest-path, circulation, or navigation methods." .
top:Path rdfs:subClassOf top:Graph .
top:Point rdf:type owl:Class .
top:Point rdfs:label "Point" .
top:Point rdfs:comment "A point-like spatial entity represented as a specialised vertex." .
top:Point rdfs:subClassOf top:Vertex .
top:Port rdf:type owl:Class .
top:Port rdfs:label "Port" .
top:Port rdfs:comment "A distribution or connection port used to represent connection points on systems, equipment, MEP components, or IFC distribution ports." .
top:PrimalGraph rdf:type owl:Class .
top:PrimalGraph rdfs:label "PrimalGraph" .
top:PrimalGraph rdfs:comment "A directed or undirected graph used to represent direct physical, spatial, topological, or semantic connectivity among entities in their original form. In spatial and topological modelling, vertices and edges typically correspond directly to objects, points, spaces, elements, or their explicit connections, before any dual transformation is applied." .
top:PrimalGraph rdfs:subClassOf top:SpatialGraph .
top:Project rdf:type owl:Class .
top:Project rdfs:label "Project" .
top:Project rdfs:comment "A project-level container used to represent a model, dataset, building project, computational study, or IFC project." .
top:Project rdfs:subClassOf prov:Entity .
top:PropertySet rdf:type owl:Class .
top:PropertySet rdfs:label "PropertySet" .
top:PropertySet rdfs:comment "A property set used to represent grouped name-value properties, commonly mapped from IFC property sets or related property-definition entities." .
top:QualityIssue rdf:type owl:Class .
top:QualityIssue rdfs:label "QualityIssue" .
top:QualityIssue rdfs:comment "A validation, model-checking, coordination, geometry, topology, semantic, or data-quality issue detected during analysis." .
top:Quantity rdf:type owl:Class .
top:Quantity rdfs:label "Quantity" .
top:Quantity rdfs:comment "A quantity record used to represent measured or computed quantities, commonly mapped from IFC element quantities." .
top:QuotientGraph rdf:type owl:Class .
top:QuotientGraph rdfs:label "QuotientGraph" .
top:QuotientGraph rdfs:comment "A directed or undirected graph used to represent a simplified graph obtained by grouping vertices, edges, spaces, zones, components, or other entities according to an equivalence relation or partition. Vertices represent groups or classes, and edges represent relationships between those groups inherited from the source graph." .
top:QuotientGraph rdfs:subClassOf top:Graph .
top:Railing rdf:type owl:Class .
top:Railing rdfs:label "Railing" .
top:Railing rdfs:comment "A railing, guard, handrail, or balustrade element." .
top:Railing rdfs:subClassOf top:Element .
top:Railing rdfs:subClassOf bot:Element .
top:Relationship rdf:type owl:Class .
top:Relationship rdfs:label "Relationship" .
top:Relationship rdfs:comment "A graph relationship represented by, or projected from, a TopologicPy edge or TGraph edge record. Relationships may carry source and target references, directionality, weights, predicates, labels, features, and dictionary metadata." .
top:Relationship rdfs:subClassOf top:Edge .
top:Roof rdf:type owl:Class .
top:Roof rdfs:label "Roof" .
top:Roof rdfs:comment "A roof or roof-like envelope element." .
top:Roof rdfs:subClassOf top:Element .
top:Roof rdfs:subClassOf bot:Element .
top:Room rdf:type owl:Class .
top:Room rdfs:label "Room" .
top:Room rdfs:comment "A room-like occupiable space represented as a specialised building space." .
top:Room rdfs:subClassOf top:Space .
top:Room rdfs:subClassOf bot:Space .
top:SemanticGraph rdf:type owl:Class .
top:SemanticGraph rdfs:label "SemanticGraph" .
top:SemanticGraph rdfs:comment "A directed graph used to represent typed entities and typed relationships with explicit semantic meaning. In TopologicPy, it may encode classes, instances, properties, labels, attributes, ontology terms, BIM semantics, or RDF-style subject-predicate-object statements." .
top:SemanticGraph rdfs:subClassOf top:Graph .
top:Sensor rdf:type owl:Class .
top:Sensor rdfs:label "Sensor" .
top:Sensor rdfs:comment "A sensor, observation point, or measurement device associated with a space, element, system, or analytical process." .
top:Sensor rdfs:subClassOf top:Element .
top:Sensor rdfs:subClassOf brick:Point .
top:Shell rdf:type owl:Class .
top:Shell rdfs:label "Shell" .
top:Shell rdfs:comment "A two-dimensional TopologicPy topology composed of connected faces, typically forming an open or closed segmented surface." .
top:Shell rdfs:subClassOf top:Topology .
top:Site rdf:type owl:Class .
top:Site rdfs:label "Site" .
top:Site rdfs:comment "A site-level spatial container used to represent land, context, parcels, infrastructure extents, or an IFC site." .
top:Site rdfs:subClassOf top:Zone .
top:Site rdfs:subClassOf bot:Site .
top:Slab rdf:type owl:Class .
top:Slab rdfs:label "Slab" .
top:Slab rdfs:comment "A slab, floor, ceiling, plate, or horizontal building element." .
top:Slab rdfs:subClassOf top:Element .
top:Slab rdfs:subClassOf bot:Element .
top:Space rdf:type owl:Class .
top:Space rdfs:label "Space" .
top:Space rdfs:comment "A bounded or occupiable spatial region used to represent rooms, spaces, compartments, or IFC spaces." .
top:Space rdfs:subClassOf top:Zone .
top:Space rdfs:subClassOf bot:Space .
top:SpaceSyntaxMetric rdf:type owl:Class .
top:SpaceSyntaxMetric rdfs:label "SpaceSyntaxMetric" .
top:SpaceSyntaxMetric rdfs:comment "A spatial network metric used in space syntax, visibility analysis, access analysis, or graph-based spatial analysis." .
top:SpaceSyntaxMetric rdfs:subClassOf top:AnalysisMetric .
top:SpatialGraph rdf:type owl:Class .
top:SpatialGraph rdfs:label "SpatialGraph" .
top:SpatialGraph rdfs:comment "A directed or undirected graph used to represent spatial entities and spatial relationships. Relationships may include metric, topological, directional, containment, proximity, overlap, visibility, accessibility, or connectivity predicates, including relations aligned with OGC Simple Features, ISO 19107 spatial schema concepts, DE-9IM predicates, or RCC-8 qualitative spatial relations." .
top:SpatialGraph rdfs:subClassOf top:Graph .
top:Stair rdf:type owl:Class .
top:Stair rdfs:label "Stair" .
top:Stair rdfs:comment "A stair, stair flight, or vertical circulation element." .
top:Stair rdfs:subClassOf top:Element .
top:Stair rdfs:subClassOf bot:Element .
top:Storey rdf:type owl:Class .
top:Storey rdfs:label "Storey" .
top:Storey rdfs:comment "A storey-level spatial container used to represent a building level, floor, or IFC building storey." .
top:Storey rdfs:subClassOf top:Zone .
top:Storey rdfs:subClassOf bot:Storey .
top:Surface rdf:type owl:Class .
top:Surface rdfs:label "Surface" .
top:Surface rdfs:comment "A surface-like spatial, analytical, or building-domain entity represented as a specialised face." .
top:Surface rdfs:subClassOf top:Face .
top:System rdf:type owl:Class .
top:System rdfs:label "System" .
top:System rdfs:comment "A building, distribution, MEP, operational, or analytical system that groups elements, equipment, ports, spaces, or functions." .
top:TGraph rdf:type owl:Class .
top:TGraph rdfs:label "TGraph" .
top:TGraph rdfs:comment "A TopologicPy-native graph representation used to represent indexed vertices, indexed edges, graph dictionaries, optional topology representations, and ontology-aware metadata. This class distinguishes the Python TGraph implementation from the more general top:Graph concept." .
top:TGraph rdfs:subClassOf top:Graph .
top:ThermalZone rdf:type owl:Class .
top:ThermalZone rdfs:label "ThermalZone" .
top:ThermalZone rdfs:comment "A thermal analysis zone represented as a specialised space used in environmental, energy, HVAC, or comfort analysis." .
top:ThermalZone rdfs:subClassOf top:Space .
top:ThermalZone rdfs:subClassOf bot:Zone .
top:Topology rdf:type owl:Class .
top:Topology rdfs:label "Topology" .
top:Topology rdfs:comment "Superclass for TopologicPy topological entities, including vertices, edges, wires, faces, shells, cells, cell complexes, clusters, apertures, and related topological specialisations." .
top:TreeGraph rdf:type owl:Class .
top:TreeGraph rdfs:label "TreeGraph" .
top:TreeGraph rdfs:comment "A connected acyclic graph used to represent hierarchical, branching, containment, decomposition, classification, or dependency structures. In TopologicPy and BIM contexts, it may represent project breakdowns, spatial decomposition, assembly hierarchies, taxonomy structures, or rooted parent-child relationships." .
top:TreeGraph rdfs:subClassOf top:Graph .
top:UndirectedRelationship rdf:type owl:Class .
top:UndirectedRelationship rdfs:label "UndirectedRelationship" .
top:UndirectedRelationship rdfs:comment "An undirected graph relationship used to represent a symmetric or direction-independent relation between two nodes." .
top:UndirectedRelationship rdfs:subClassOf top:Relationship .
top:ValidationRule rdf:type owl:Class .
top:ValidationRule rdfs:label "ValidationRule" .
top:ValidationRule rdfs:comment "A rule used to validate geometry, topology, semantics, IFC/BIM content, graph structure, provenance, or analytical metadata." .
top:Vector rdf:type owl:Class .
top:Vector rdfs:label "Vector" .
top:Vector rdfs:comment "A mathematical vector used to represent direction, displacement, orientation, or other vector-valued quantities." .
top:Vertex rdf:type owl:Class .
top:Vertex rdfs:label "Vertex" .
top:Vertex rdfs:comment "A zero-dimensional TopologicPy topology representing a point-like entity, commonly defined by X, Y, and Z coordinates." .
top:Vertex rdfs:subClassOf top:Topology .
top:VisibilityGraph rdf:type owl:Class .
top:VisibilityGraph rdfs:label "VisibilityGraph" .
top:VisibilityGraph rdfs:comment "An undirected or directed spatial graph used to represent line-of-sight visibility or intervisibility between points, locations, spaces, surfaces, objects, or sampled positions. Edges indicate that two entities are mutually visible or directionally visible, and may store visibility distance, angular range, obstruction status, or visual weight." .
top:VisibilityGraph rdfs:subClassOf top:SpatialGraph .
top:Wall rdf:type owl:Class .
top:Wall rdfs:label "Wall" .
top:Wall rdfs:comment "A wall or wall-like building element used to bound, separate, support, enclose, or subdivide spaces." .
top:Wall rdfs:subClassOf top:Element .
top:Wall rdfs:subClassOf bot:Element .
top:Window rdf:type owl:Class .
top:Window rdfs:label "Window" .
top:Window rdfs:comment "A window or transparent/translucent opening element, commonly associated with daylight, view, envelope, and façade relationships." .
