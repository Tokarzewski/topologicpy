top:Window rdfs:subClassOf bot:Element .
top:Wire rdf:type owl:Class .
top:Wire rdfs:label "Wire" .
top:Wire rdfs:comment "A one-dimensional TopologicPy topology composed of connected edges, typically forming an open path or a closed boundary." .
top:Wire rdfs:subClassOf top:Topology .
top:Zone rdf:type owl:Class .
top:Zone rdfs:label "Zone" .
top:Zone rdfs:comment "A spatial region, bounded domain, or analytical zone used to organise spaces, buildings, storeys, sites, thermal zones, or functional regions." .
