@base <http://w3id.org/topologicpy/> .
@prefix top: <http://w3id.org/topologicpy#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix brick: <https://brickschema.org/schema/Brick#> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix ifc: <https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2_TC1/OWL#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<http://w3id.org/topologicpy>
    rdf:type owl:Ontology ;
    dcterms:title "TopologicPy Ontology"@en ;
    dcterms:description "A compact OWL/RDFS vocabulary for TopologicPy topology, graph, BIM/IFC/BOT/Brick alignment, dictionary metadata, semantic edge predicates, graph-machine-learning metadata, provenance, and analysis results."@en ;
    dcterms:creator "TopologicPy Project"@en ;
    dcterms:contributor "Wassim Jabi"@en ;
    dcterms:license <https://www.gnu.org/licenses/agpl-3.0.en.html> ;
    dcterms:issued "2026-05-24"^^xsd:date ;
    dcterms:modified "2026-07-01"^^xsd:date ;
    owl:versionInfo "0.4.0" ;
    vann:preferredNamespacePrefix "top" ;
    vann:preferredNamespaceUri "http://w3id.org/topologicpy#" ;
    rdfs:label "TopologicPy Ontology"@en ;
    rdfs:comment "The canonical namespace prefix is top:. BOT, Brick, GeoSPARQL, IFC, PROV-O, SKOS, RDF, RDFS, OWL, and XSD terms are referenced for interoperability but are not redefined here."@en .

# =============================================================================
# Core topology, utility, graph, BIM, analysis, and metadata classes
# =============================================================================

top:Topology rdf:type owl:Class ;
    rdfs:label "Topology"@en ;
    rdfs:comment "Superclass for TopologicPy topological entities, including vertices, edges, wires, faces, shells, cells, cell complexes, clusters, apertures, and related topological specialisations."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Vertex rdf:type owl:Class ;
    rdfs:subClassOf top:Topology ;
    rdfs:label "Vertex"@en ;
    rdfs:comment "A zero-dimensional TopologicPy topology representing a point-like entity, commonly defined by X, Y, and Z coordinates."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Edge rdf:type owl:Class ;
    rdfs:subClassOf top:Topology ;
    rdfs:label "Edge"@en ;
    rdfs:comment "A one-dimensional TopologicPy topology connecting a start vertex to an end vertex."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Wire rdf:type owl:Class ;
    rdfs:subClassOf top:Topology ;
    rdfs:label "Wire"@en ;
    rdfs:comment "A one-dimensional TopologicPy topology composed of connected edges, typically forming an open path or a closed boundary."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Face rdf:type owl:Class ;
    rdfs:subClassOf top:Topology ;
    rdfs:label "Face"@en ;
    rdfs:comment "A two-dimensional TopologicPy topology bounded by an external wire and, optionally, one or more internal boundary wires."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Shell rdf:type owl:Class ;
    rdfs:subClassOf top:Topology ;
    rdfs:label "Shell"@en ;
    rdfs:comment "A two-dimensional TopologicPy topology composed of connected faces, typically forming an open or closed segmented surface."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Cell rdf:type owl:Class ;
    rdfs:subClassOf top:Topology ;
    rdfs:label "Cell"@en ;
    rdfs:comment "A three-dimensional TopologicPy topology bounded by faces or shells and representing a volumetric region."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:CellComplex rdf:type owl:Class ;
    rdfs:subClassOf top:Topology ;
    rdfs:label "CellComplex"@en ;
    rdfs:comment "A TopologicPy topology composed of cells, typically with non-manifold adjacency through shared faces."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Cluster rdf:type owl:Class ;
    rdfs:subClassOf top:Topology ;
    rdfs:label "Cluster"@en ;
    rdfs:comment "A heterogeneous TopologicPy topology used to group vertices, edges, wires, faces, shells, cells, cell complexes, or other clusters without requiring manifold connectivity."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Aperture rdf:type owl:Class ;
    rdfs:subClassOf top:Face ;
    rdfs:subClassOf top:Element ;
    rdfs:label "Aperture"@en ;
    rdfs:comment "A topological or building-domain opening associated with a host topology or element. In TopologicPy it is treated as an aperture/opening construct and may be represented geometrically by a face-like boundary."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Dictionary rdf:type owl:Class ;
    rdfs:label "Dictionary"@en ;
    rdfs:comment "A key-value metadata container used by TopologicPy to attach semantic, analytical, geometric, provenance, and interoperability data to topologies, graphs, vertices, edges, and records."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Context rdf:type owl:Class ;
    rdfs:label "Context"@en ;
    rdfs:comment "A contextual reference used by TopologicPy to associate content with a host topology or subtopology."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Vector rdf:type owl:Class ;
    rdfs:label "Vector"@en ;
    rdfs:comment "A mathematical vector used to represent direction, displacement, orientation, or other vector-valued quantities."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Matrix rdf:type owl:Class ;
    rdfs:label "Matrix"@en ;
    rdfs:comment "A numerical matrix used to represent transformations, coordinate operations, or other matrix-valued quantities."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Grid rdf:type owl:Class ;
    rdfs:label "Grid"@en ;
    rdfs:comment "A spatial subdivision, sampling, or reference structure used to generate or organise vertices, edges, cells, or analysis samples."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Attribute rdf:type owl:Class ;
    rdfs:label "Attribute"@en ;
    rdfs:comment "A semantic or analytical key-value attribute associated with a topology, graph, node, relationship, dataset, metric, or external entity."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Point rdf:type owl:Class ;
    rdfs:subClassOf top:Vertex ;
    rdfs:label "Point"@en ;
    rdfs:comment "A point-like spatial entity represented as a specialised vertex."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Surface rdf:type owl:Class ;
    rdfs:subClassOf top:Face ;
    rdfs:label "Surface"@en ;
    rdfs:comment "A surface-like spatial, analytical, or building-domain entity represented as a specialised face."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Boundary rdf:type owl:Class ;
    rdfs:subClassOf top:Topology ;
    rdfs:label "Boundary"@en ;
    rdfs:comment "A topology used to represent the boundary of another topology, spatial region, element, or analytical domain."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:ExternalBoundary rdf:type owl:Class ;
    rdfs:subClassOf top:Boundary ;
    rdfs:label "ExternalBoundary"@en ;
    rdfs:comment "A boundary topology used to represent the outer boundary of another topology, region, element, or analytical domain."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:InternalBoundary rdf:type owl:Class ;
    rdfs:subClassOf top:Boundary ;
    rdfs:label "InternalBoundary"@en ;
    rdfs:comment "A boundary topology used to represent a hole, void, inner loop, or internal boundary of another topology, region, element, or analytical domain."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Graph rdf:type owl:Class ;
    rdfs:label "Graph"@en ;
    rdfs:comment "A directed, undirected, mixed, weighted, unweighted, simple, or multigraph representation used to represent entities and relationships emitted, consumed, analysed, or transformed by TopologicPy. More specific graph semantics are defined by subclasses."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:TGraph rdf:type owl:Class ;
    rdfs:subClassOf top:Graph ;
    rdfs:label "TGraph"@en ;
    rdfs:comment "A TopologicPy-native graph representation used to represent indexed vertices, indexed edges, graph dictionaries, optional topology representations, and ontology-aware metadata. This class distinguishes the Python TGraph implementation from the more general top:Graph concept."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Node rdf:type owl:Class ;
    rdfs:subClassOf top:Vertex ;
    rdfs:label "Node"@en ;
    rdfs:comment "A graph node represented by, or projected from, a TopologicPy vertex or TGraph vertex record. Nodes may carry dictionary metadata, ontology class information, labels, features, coordinates, and external identifiers."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Relationship rdf:type owl:Class ;
    rdfs:subClassOf top:Edge ;
    rdfs:label "Relationship"@en ;
    rdfs:comment "A graph relationship represented by, or projected from, a TopologicPy edge or TGraph edge record. Relationships may carry source and target references, directionality, weights, predicates, labels, features, and dictionary metadata."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:DirectedRelationship rdf:type owl:Class ;
    rdfs:subClassOf top:Relationship ;
    rdfs:label "DirectedRelationship"@en ;
    rdfs:comment "A directed graph relationship used to represent an ordered source-to-target relation between two nodes."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:UndirectedRelationship rdf:type owl:Class ;
    rdfs:subClassOf top:Relationship ;
    rdfs:label "UndirectedRelationship"@en ;
    rdfs:comment "An undirected graph relationship used to represent a symmetric or direction-independent relation between two nodes."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:SpatialGraph rdf:type owl:Class ;
    rdfs:subClassOf top:Graph ;
    rdfs:label "SpatialGraph"@en ;
    rdfs:comment "A directed or undirected graph used to represent spatial entities and spatial relationships. Relationships may include metric, topological, directional, containment, proximity, overlap, visibility, accessibility, or connectivity predicates, including relations aligned with OGC Simple Features, ISO 19107 spatial schema concepts, DE-9IM predicates, or RCC-8 qualitative spatial relations."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:AccessGraph rdf:type owl:Class ;
    rdfs:subClassOf top:SpatialGraph ;
    rdfs:label "AccessGraph"@en ;
    rdfs:comment "A directed or undirected graph used to represent permitted access between spaces, rooms, zones, portals, doors, apertures, circulation elements, or other traversable entities. Edges may encode passability, access control, traversal direction, door type, cost, distance, or movement constraints."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:AdjacencyGraph rdf:type owl:Class ;
    rdfs:subClassOf top:SpatialGraph ;
    rdfs:label "AdjacencyGraph"@en ;
    rdfs:comment "An undirected graph used to represent adjacency between topological, geometric, spatial, or semantic entities. Edges typically indicate that two entities touch, share a boundary, are incident, are proximal within a specified tolerance, or satisfy a declared adjacency predicate."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:AnalysisGraph rdf:type owl:Class ;
    rdfs:subClassOf top:Graph ;
    rdfs:label "AnalysisGraph"@en ;
    rdfs:comment "A directed or undirected graph used to represent entities and relationships prepared for computational analysis. Vertices, edges, and graph-level dictionaries may encode analytical attributes, weights, labels, features, metrics, simulation values, or machine-learning inputs and outputs."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:CirculationGraph rdf:type owl:Class ;
    rdfs:subClassOf top:SpatialGraph ;
    rdfs:label "CirculationGraph"@en ;
    rdfs:comment "A directed or undirected graph used to represent movement, circulation, or route-choice relationships among spaces, portals, corridors, stairs, entrances, exits, or waypoints. Edges may encode route length, cost, capacity, direction, or accessibility."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:ConnectivityGraph rdf:type owl:Class ;
    rdfs:subClassOf top:SpatialGraph ;
    rdfs:label "ConnectivityGraph"@en ;
    rdfs:comment "A directed or undirected graph used to represent generic connectivity or reachability among topological, spatial, building, system, or graph entities. Edges indicate that two entities are connected according to an explicit computational or semantic rule."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:DualGraph rdf:type owl:Class ;
    rdfs:subClassOf top:SpatialGraph ;
    rdfs:label "DualGraph"@en ;
    rdfs:comment "An undirected graph used to represent adjacency between higher-dimensional entities such as faces, cells, rooms, spaces, zones, or regions. Each entity is represented as a vertex, and an edge represents a shared boundary, interface, aperture, adjacency relation, or other declared connection between two entities."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:HasseDiagramGraph rdf:type owl:Class ;
    rdfs:subClassOf top:Graph ;
    rdfs:label "HasseDiagramGraph"@en ;
    rdfs:comment "A directed acyclic graph used to represent a partially ordered set, typically by showing only cover relations after transitive reduction. In TopologicPy, it may represent hierarchical containment, decomposition, incidence, or boundary relationships among topological entities."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:IsovistGraph rdf:type owl:Class ;
    rdfs:subClassOf top:SpatialGraph ;
    rdfs:label "IsovistGraph"@en ;
    rdfs:comment "A directed or undirected spatial graph used to represent isovists, visibility fields, or relationships between observation points and visible spatial extents. Vertices may represent viewpoints, isovist polygons, spatial samples, or visible objects, while edges may encode visibility, overlap, containment, or intervisibility relationships."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:KnowledgeGraph rdf:type owl:Class ;
    rdfs:subClassOf top:Graph ;
    rdfs:label "KnowledgeGraph"@en ;
    rdfs:comment "A directed semantic graph used to represent entities, attributes, relationships, and inferred knowledge. In TopologicPy, it may encode topological objects, BIM entities, ontology classes, RDF triples, rules, reasoning outputs, or links between geometry, topology, semantics, analysis, and external knowledge sources."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:LineGraph rdf:type owl:Class ;
    rdfs:subClassOf top:Graph ;
    rdfs:label "LineGraph"@en ;
    rdfs:comment "An undirected or directed graph used to represent edge-to-edge relationships derived from another graph. Each vertex in the line graph represents an edge of the source graph, and each edge in the line graph represents adjacency, incidence, continuity, succession, or compatibility between source edges."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:NavigationGraph rdf:type owl:Class ;
    rdfs:subClassOf top:SpatialGraph ;
    rdfs:label "NavigationGraph"@en ;
    rdfs:comment "A directed or undirected weighted graph used to represent navigable movement through spaces, paths, portals, waypoints, circulation systems, or walkable regions. Edges typically encode traversability and may store distance, travel time, slope, accessibility, obstruction, cost, or agent-specific movement constraints."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:PrimalGraph rdf:type owl:Class ;
    rdfs:subClassOf top:SpatialGraph ;
    rdfs:label "PrimalGraph"@en ;
    rdfs:comment "A directed or undirected graph used to represent direct physical, spatial, topological, or semantic connectivity among entities in their original form. In spatial and topological modelling, vertices and edges typically correspond directly to objects, points, spaces, elements, or their explicit connections, before any dual transformation is applied."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:QuotientGraph rdf:type owl:Class ;
    rdfs:subClassOf top:Graph ;
    rdfs:label "QuotientGraph"@en ;
    rdfs:comment "A directed or undirected graph used to represent a simplified graph obtained by grouping vertices, edges, spaces, zones, components, or other entities according to an equivalence relation or partition. Vertices represent groups or classes, and edges represent relationships between those groups inherited from the source graph."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:SemanticGraph rdf:type owl:Class ;
    rdfs:subClassOf top:Graph ;
    rdfs:label "SemanticGraph"@en ;
    rdfs:comment "A directed graph used to represent typed entities and typed relationships with explicit semantic meaning. In TopologicPy, it may encode classes, instances, properties, labels, attributes, ontology terms, BIM semantics, or RDF-style subject-predicate-object statements."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:TreeGraph rdf:type owl:Class ;
    rdfs:subClassOf top:Graph ;
    rdfs:label "TreeGraph"@en ;
    rdfs:comment "A connected acyclic graph used to represent hierarchical, branching, containment, decomposition, classification, or dependency structures. In TopologicPy and BIM contexts, it may represent project breakdowns, spatial decomposition, assembly hierarchies, taxonomy structures, or rooted parent-child relationships."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:VisibilityGraph rdf:type owl:Class ;
    rdfs:subClassOf top:SpatialGraph ;
    rdfs:label "VisibilityGraph"@en ;
    rdfs:comment "An undirected or directed spatial graph used to represent line-of-sight visibility or intervisibility between points, locations, spaces, surfaces, objects, or sampled positions. Edges indicate that two entities are mutually visible or directionally visible, and may store visibility distance, angular range, obstruction status, or visual weight."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:GraphDataset rdf:type owl:Class ;
    rdfs:label "GraphDataset"@en ;
    rdfs:comment "A dataset used to represent graphs, nodes, edges, labels, masks, features, metadata, and ontology annotations for graph analysis or graph machine learning."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:GraphFeature rdf:type owl:Class ;
    rdfs:subClassOf top:Attribute ;
    rdfs:label "GraphFeature"@en ;
    rdfs:comment "A numerical, categorical, vector, or encoded feature associated with a graph-level record."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:NodeFeature rdf:type owl:Class ;
    rdfs:subClassOf top:Attribute ;
    rdfs:label "NodeFeature"@en ;
    rdfs:comment "A numerical, categorical, vector, or encoded feature associated with a graph node or vertex record."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:EdgeFeature rdf:type owl:Class ;
    rdfs:subClassOf top:Attribute ;
    rdfs:label "EdgeFeature"@en ;
    rdfs:comment "A numerical, categorical, vector, or encoded feature associated with a graph edge or relationship record."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Path rdf:type owl:Class ;
    rdfs:subClassOf top:Graph ;
    rdfs:label "Path"@en ;
    rdfs:comment "An ordered graph structure used to represent a sequence of nodes and relationships, typically returned by routing, shortest-path, circulation, or navigation methods."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Project rdf:type owl:Class ;
    rdfs:subClassOf prov:Entity ;
    rdfs:label "Project"@en ;
    rdfs:comment "A project-level container used to represent a model, dataset, building project, computational study, or IFC project."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Zone rdf:type owl:Class ;
    rdfs:subClassOf top:Cell ;
    rdfs:subClassOf bot:Zone ;
    rdfs:label "Zone"@en ;
    rdfs:comment "A spatial region, bounded domain, or analytical zone used to organise spaces, buildings, storeys, sites, thermal zones, or functional regions."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Site rdf:type owl:Class ;
    rdfs:subClassOf top:Zone ;
    rdfs:subClassOf bot:Site ;
    rdfs:label "Site"@en ;
    rdfs:comment "A site-level spatial container used to represent land, context, parcels, infrastructure extents, or an IFC site."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Building rdf:type owl:Class ;
    rdfs:subClassOf top:Zone ;
    rdfs:subClassOf bot:Building ;
    rdfs:label "Building"@en ;
    rdfs:comment "A building-level spatial container used to represent a whole building, facility, or IFC building."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Storey rdf:type owl:Class ;
    rdfs:subClassOf top:Zone ;
    rdfs:subClassOf bot:Storey ;
    rdfs:label "Storey"@en ;
    rdfs:comment "A storey-level spatial container used to represent a building level, floor, or IFC building storey."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Space rdf:type owl:Class ;
    rdfs:subClassOf top:Zone ;
    rdfs:subClassOf bot:Space ;
    rdfs:label "Space"@en ;
    rdfs:comment "A bounded or occupiable spatial region used to represent rooms, spaces, compartments, or IFC spaces."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Room rdf:type owl:Class ;
    rdfs:subClassOf top:Space ;
    rdfs:label "Room"@en ;
    rdfs:comment "A room-like occupiable space represented as a specialised building space."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:ThermalZone rdf:type owl:Class ;
    rdfs:subClassOf top:Space ;
    rdfs:label "ThermalZone"@en ;
    rdfs:comment "A thermal analysis zone represented as a specialised space used in environmental, energy, HVAC, or comfort analysis."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:FunctionalZone rdf:type owl:Class ;
    rdfs:subClassOf top:Zone ;
    rdfs:label "FunctionalZone"@en ;
    rdfs:comment "A zone grouped by use, function, programme, activity, department, or other non-geometric classification."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:CirculationZone rdf:type owl:Class ;
    rdfs:subClassOf top:Zone ;
    rdfs:label "CirculationZone"@en ;
    rdfs:comment "A zone primarily used to represent movement, access, circulation, transition, or evacuation functions."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Element rdf:type owl:Class ;
    rdfs:subClassOf top:Topology ;
    rdfs:subClassOf bot:Element ;
    rdfs:label "Element"@en ;
    rdfs:comment "A physical, conceptual, or analytical building/infrastructure element that may be represented by topology and aligned with BIM entities."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Wall rdf:type owl:Class ;
    rdfs:subClassOf top:Element ;
    rdfs:label "Wall"@en ;
    rdfs:comment "A wall or wall-like building element used to bound, separate, support, enclose, or subdivide spaces."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:CurtainWall rdf:type owl:Class ;
    rdfs:subClassOf top:Wall ;
    rdfs:label "CurtainWall"@en ;
    rdfs:comment "A curtain-wall element represented as a specialised wall or façade system."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Door rdf:type owl:Class ;
    rdfs:subClassOf top:Element ;
    rdfs:label "Door"@en ;
    rdfs:comment "A door, access, or operable passage element, commonly associated with openings, access graphs, and navigation relationships."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Window rdf:type owl:Class ;
    rdfs:subClassOf top:Element ;
    rdfs:label "Window"@en ;
    rdfs:comment "A window or transparent/translucent opening element, commonly associated with daylight, view, envelope, and façade relationships."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Slab rdf:type owl:Class ;
    rdfs:subClassOf top:Element ;
    rdfs:label "Slab"@en ;
    rdfs:comment "A slab, floor, ceiling, plate, or horizontal building element."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Roof rdf:type owl:Class ;
    rdfs:subClassOf top:Element ;
    rdfs:label "Roof"@en ;
    rdfs:comment "A roof or roof-like envelope element."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Column rdf:type owl:Class ;
    rdfs:subClassOf top:Element ;
    rdfs:label "Column"@en ;
    rdfs:comment "A column or vertical structural member."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Beam rdf:type owl:Class ;
    rdfs:subClassOf top:Element ;
    rdfs:label "Beam"@en ;
    rdfs:comment "A beam, girder, or linear structural member."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Member rdf:type owl:Class ;
    rdfs:subClassOf top:Element ;
    rdfs:label "Member"@en ;
    rdfs:comment "A generic structural, framing, or linear member when a more specific class such as Beam or Column is not asserted."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Stair rdf:type owl:Class ;
    rdfs:subClassOf top:Element ;
    rdfs:label "Stair"@en ;
    rdfs:comment "A stair, stair flight, or vertical circulation element."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Railing rdf:type owl:Class ;
    rdfs:subClassOf top:Element ;
    rdfs:label "Railing"@en ;
    rdfs:comment "A railing, guard, handrail, or balustrade element."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Opening rdf:type owl:Class ;
    rdfs:subClassOf top:Element ;
    rdfs:label "Opening"@en ;
    rdfs:comment "An opening element, void, recess, penetration, or host-element subtraction associated with doors, windows, services, or coordination checks."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Furniture rdf:type owl:Class ;
    rdfs:subClassOf top:Element ;
    rdfs:label "Furniture"@en ;
    rdfs:comment "A furniture or furnishing element."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Equipment rdf:type owl:Class ;
    rdfs:subClassOf top:Element ;
    rdfs:subClassOf brick:Equipment ;
    rdfs:label "Equipment"@en ;
    rdfs:comment "A building, MEP, operational, or service equipment element, optionally aligned with Brick equipment classes when system semantics are available."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Sensor rdf:type owl:Class ;
    rdfs:subClassOf top:Element ;
    rdfs:subClassOf brick:Point ;
    rdfs:label "Sensor"@en ;
    rdfs:comment "A sensor, observation point, or measurement device associated with a space, element, system, or analytical process."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Interface rdf:type owl:Class ;
    rdfs:subClassOf top:Face ;
    rdfs:subClassOf bot:Interface ;
    rdfs:label "Interface"@en ;
    rdfs:comment "A shared boundary or interface between spaces, zones, elements, or topologies, including IFC space-boundary-style relationships."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Port rdf:type owl:Class ;
    rdfs:label "Port"@en ;
    rdfs:comment "A distribution or connection port used to represent connection points on systems, equipment, MEP components, or IFC distribution ports."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:System rdf:type owl:Class ;
    rdfs:label "System"@en ;
    rdfs:comment "A building, distribution, MEP, operational, or analytical system that groups elements, equipment, ports, spaces, or functions."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:PropertySet rdf:type owl:Class ;
    rdfs:label "PropertySet"@en ;
    rdfs:comment "A property set used to represent grouped name-value properties, commonly mapped from IFC property sets or related property-definition entities."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Quantity rdf:type owl:Class ;
    rdfs:label "Quantity"@en ;
    rdfs:comment "A quantity record used to represent measured or computed quantities, commonly mapped from IFC element quantities."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Material rdf:type owl:Class ;
    rdfs:label "Material"@en ;
    rdfs:comment "A material record used to represent material identity, composition, assignment, or IFC material information."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:MaterialSet rdf:type owl:Class ;
    rdfs:label "MaterialSet"@en ;
    rdfs:comment "A material-set record used to represent material lists, material layer sets, material constituent sets, or other grouped material definitions."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:ClassificationReference rdf:type owl:Class ;
    rdfs:label "ClassificationReference"@en ;
    rdfs:comment "A classification reference used to represent external classification systems, codes, taxonomies, or IFC classification references."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:AnalysisMetric rdf:type owl:Class ;
    rdfs:label "AnalysisMetric"@en ;
    rdfs:comment "A computed metric associated with geometry, topology, graphs, buildings, systems, simulation, performance analysis, or machine-learning workflows."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:SpaceSyntaxMetric rdf:type owl:Class ;
    rdfs:subClassOf top:AnalysisMetric ;
    rdfs:label "SpaceSyntaxMetric"@en ;
    rdfs:comment "A spatial network metric used in space syntax, visibility analysis, access analysis, or graph-based spatial analysis."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:Isovist rdf:type owl:Class ;
    rdfs:subClassOf top:AnalysisMetric ;
    rdfs:label "Isovist"@en ;
    rdfs:comment "A visibility field, polygon, volume, or related visual metric computed from an observation point or region."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:QualityIssue rdf:type owl:Class ;
    rdfs:label "QualityIssue"@en ;
    rdfs:comment "A validation, model-checking, coordination, geometry, topology, semantic, or data-quality issue detected during analysis."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:ValidationRule rdf:type owl:Class ;
    rdfs:label "ValidationRule"@en ;
    rdfs:comment "A rule used to validate geometry, topology, semantics, IFC/BIM content, graph structure, provenance, or analytical metadata."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

# =============================================================================
# Object properties
# =============================================================================

top:hasDictionary rdf:type owl:ObjectProperty ;
    rdfs:domain top:Topology, top:Graph ;
    rdfs:range top:Dictionary ;
    rdfs:label "has dictionary"@en ;
    rdfs:comment "Associates a topology, graph, node, relationship, or record with a TopologicPy dictionary containing metadata, attributes, semantics, analysis values, or provenance."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:hasTopology rdf:type owl:ObjectProperty ;
    rdfs:range top:Topology ;
    owl:inverseOf top:isTopologyOf ;
    rdfs:label "has topology"@en ;
    rdfs:comment "Associates an entity with a topology that geometrically or topologically represents it."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:isTopologyOf rdf:type owl:ObjectProperty ;
    rdfs:domain top:Topology ;
    rdfs:label "is topology of"@en ;
    rdfs:comment "Inverse relation of top:hasTopology, associating a topology with the entity it represents."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:hasSubTopology rdf:type owl:ObjectProperty ;
    rdfs:domain top:Topology ;
    rdfs:range top:Topology ;
    owl:inverseOf top:isSubTopologyOf ;
    rdfs:label "has subtopology"@en ;
    rdfs:comment "Associates a topology with a contained or constituent subtopology."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:isSubTopologyOf rdf:type owl:ObjectProperty ;
    rdfs:domain top:Topology ;
    rdfs:range top:Topology ;
    rdfs:label "is subtopology of"@en ;
    rdfs:comment "Associates a topology with a containing or parent topology."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:hasVertex rdf:type owl:ObjectProperty ;
    rdfs:domain top:Topology, top:Graph ;
    rdfs:range top:Vertex ;
    rdfs:subPropertyOf top:hasSubTopology ;
    owl:inverseOf top:isVertexOf ;
    rdfs:label "has vertex"@en ;
    rdfs:comment "Associates a topology or graph with a vertex that belongs to it."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:isVertexOf rdf:type owl:ObjectProperty ;
    rdfs:domain top:Vertex ;
    rdfs:range top:Topology, top:Graph ;
    rdfs:subPropertyOf top:isSubTopologyOf ;
    rdfs:label "is vertex of"@en ;
    rdfs:comment "Associates a vertex with the topology or graph to which it belongs."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:hasEdge rdf:type owl:ObjectProperty ;
    rdfs:domain top:Topology, top:Graph ;
    rdfs:range top:Edge ;
    rdfs:subPropertyOf top:hasSubTopology ;
    owl:inverseOf top:isEdgeOf ;
    rdfs:label "has edge"@en ;
    rdfs:comment "Associates a topology or graph with an edge that belongs to it."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:isEdgeOf rdf:type owl:ObjectProperty ;
    rdfs:domain top:Edge ;
    rdfs:range top:Topology, top:Graph ;
    rdfs:subPropertyOf top:isSubTopologyOf ;
    rdfs:label "is edge of"@en ;
    rdfs:comment "Associates an edge with the topology or graph to which it belongs."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:hasWire rdf:type owl:ObjectProperty ;
    rdfs:domain top:Topology ;
    rdfs:range top:Wire ;
    rdfs:subPropertyOf top:hasSubTopology ;
    owl:inverseOf top:isWireOf ;
    rdfs:label "has wire"@en ;
    rdfs:comment "Associates a topology with a constituent wire."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:isWireOf rdf:type owl:ObjectProperty ;
    rdfs:domain top:Wire ;
    rdfs:range top:Topology ;
    rdfs:subPropertyOf top:isSubTopologyOf ;
    rdfs:label "is wire of"@en ;
    rdfs:comment "Associates a wire with its parent topology."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:hasFace rdf:type owl:ObjectProperty ;
    rdfs:domain top:Topology ;
    rdfs:range top:Face ;
    rdfs:subPropertyOf top:hasSubTopology ;
    owl:inverseOf top:isFaceOf ;
    rdfs:label "has face"@en ;
    rdfs:comment "Associates a topology with a constituent face."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:isFaceOf rdf:type owl:ObjectProperty ;
    rdfs:domain top:Face ;
    rdfs:range top:Topology ;
    rdfs:subPropertyOf top:isSubTopologyOf ;
    rdfs:label "is face of"@en ;
    rdfs:comment "Associates a face with its parent topology."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:hasShell rdf:type owl:ObjectProperty ;
    rdfs:domain top:Topology ;
    rdfs:range top:Shell ;
    rdfs:subPropertyOf top:hasSubTopology ;
    owl:inverseOf top:isShellOf ;
    rdfs:label "has shell"@en ;
    rdfs:comment "Associates a topology with a constituent shell."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:isShellOf rdf:type owl:ObjectProperty ;
    rdfs:domain top:Shell ;
    rdfs:range top:Topology ;
    rdfs:subPropertyOf top:isSubTopologyOf ;
    rdfs:label "is shell of"@en ;
    rdfs:comment "Associates a shell with its parent topology."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:hasCell rdf:type owl:ObjectProperty ;
    rdfs:domain top:Topology ;
    rdfs:range top:Cell ;
    rdfs:subPropertyOf top:hasSubTopology ;
    owl:inverseOf top:isCellOf ;
    rdfs:label "has cell"@en ;
    rdfs:comment "Associates a topology with a constituent cell."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:isCellOf rdf:type owl:ObjectProperty ;
    rdfs:domain top:Cell ;
    rdfs:range top:Topology ;
    rdfs:subPropertyOf top:isSubTopologyOf ;
    rdfs:label "is cell of"@en ;
    rdfs:comment "Associates a cell with its parent topology."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:hasCellComplex rdf:type owl:ObjectProperty ;
    rdfs:domain top:Cluster ;
    rdfs:range top:CellComplex ;
    rdfs:subPropertyOf top:hasSubTopology ;
    owl:inverseOf top:isCellComplexOf ;
    rdfs:label "has cell complex"@en ;
    rdfs:comment "Associates a cluster or model container with a constituent cell complex."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:isCellComplexOf rdf:type owl:ObjectProperty ;
    rdfs:domain top:CellComplex ;
    rdfs:range top:Cluster ;
    rdfs:subPropertyOf top:isSubTopologyOf ;
    rdfs:label "is cell complex of"@en ;
    rdfs:comment "Associates a cell complex with a containing cluster or model container."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:hasExternalBoundary rdf:type owl:ObjectProperty ;
    rdfs:domain top:Topology ;
    rdfs:range top:Boundary ;
    rdfs:label "has external boundary"@en ;
    rdfs:comment "Associates a topology, region, element, or analytical domain with its external boundary."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:hasInternalBoundary rdf:type owl:ObjectProperty ;
    rdfs:domain top:Topology ;
    rdfs:range top:Boundary ;
    rdfs:label "has internal boundary"@en ;
    rdfs:comment "Associates a topology, region, element, or analytical domain with an internal boundary, hole, or void boundary."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:hasStartVertex rdf:type owl:ObjectProperty ;
    rdfs:domain top:Edge, top:Relationship ;
    rdfs:range top:Vertex ;
    rdfs:label "has start vertex"@en ;
    rdfs:comment "Associates an edge or relationship with its start vertex or source node."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:hasEndVertex rdf:type owl:ObjectProperty ;
    rdfs:domain top:Edge, top:Relationship ;
    rdfs:range top:Vertex ;
    rdfs:label "has end vertex"@en ;
    rdfs:comment "Associates an edge or relationship with its end vertex or target node."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:startsAt rdf:type owl:ObjectProperty ;
    rdfs:domain top:Edge, top:Relationship ;
    rdfs:range top:Vertex ;
    owl:equivalentProperty top:hasStartVertex ;
    rdfs:label "starts at"@en ;
    rdfs:comment "Alias property for associating an edge or relationship with its start vertex or source node."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:endsAt rdf:type owl:ObjectProperty ;
    rdfs:domain top:Edge, top:Relationship ;
    rdfs:range top:Vertex ;
    owl:equivalentProperty top:hasEndVertex ;
    rdfs:label "ends at"@en ;
    rdfs:comment "Alias property for associating an edge or relationship with its end vertex or target node."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:connectsTo rdf:type owl:ObjectProperty, owl:SymmetricProperty ;
    rdfs:domain top:Topology ;
    rdfs:range top:Topology ;
    rdfs:subPropertyOf bot:connectsTo ;
    rdfs:label "connects to"@en ;
    rdfs:comment "Generic undirected topological or graph connectivity between two topologies, vertices, nodes, elements, spaces, or other entities."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:connects rdf:type owl:ObjectProperty, owl:SymmetricProperty ;
    rdfs:domain top:Topology ;
    rdfs:range top:Topology ;
    rdfs:label "connects"@en ;
    rdfs:comment "Generic semantic connection used when a relationship is known but more specific semantics are unavailable."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:isConnectedTo rdf:type owl:ObjectProperty, owl:SymmetricProperty ;
    rdfs:domain top:Topology ;
    rdfs:range top:Topology ;
    owl:equivalentProperty top:connects ;
    rdfs:label "is connected to"@en ;
    rdfs:comment "Alias property for generic semantic or topological connection."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:adjacentTo rdf:type owl:ObjectProperty, owl:SymmetricProperty ;
    rdfs:domain top:Topology ;
    rdfs:range top:Topology ;
    rdfs:subPropertyOf bot:adjacentTo ;
    rdfs:label "adjacent to"@en ;
    rdfs:comment "Associates two topologies, spaces, regions, or elements that are adjacent according to a declared spatial, topological, or tolerance-based rule."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:interfaceOf rdf:type owl:ObjectProperty ;
    rdfs:domain top:Interface ;
    rdfs:range top:Topology ;
    rdfs:subPropertyOf bot:interfaceOf ;
    rdfs:label "interface of"@en ;
    rdfs:comment "Associates an interface with the topology, element, space, or zone that it bounds, separates, or connects."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:hasNode rdf:type owl:ObjectProperty ;
    rdfs:domain top:Graph ;
    rdfs:range top:Node ;
    rdfs:label "has node"@en ;
    rdfs:comment "Associates a graph with a node that belongs to it."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:hasRelationship rdf:type owl:ObjectProperty ;
    rdfs:domain top:Graph ;
    rdfs:range top:Relationship ;
    rdfs:label "has relationship"@en ;
    rdfs:comment "Associates a graph with a relationship or edge that belongs to it."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:hasPredicate rdf:type owl:ObjectProperty ;
    rdfs:domain top:Relationship ;
    rdfs:range rdf:Property ;
    rdfs:label "has predicate"@en ;
    rdfs:comment "Associates a TopologicPy relationship record with the RDF predicate that gives the relationship its semantic meaning."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:hasConnectedPort rdf:type owl:ObjectProperty ;
    rdfs:domain top:Element ;
    rdfs:range top:Port ;
    rdfs:label "has connected port"@en ;
    rdfs:comment "Associates an element, system component, or equipment item with a connected distribution or connection port."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:connectsPort rdf:type owl:ObjectProperty, owl:SymmetricProperty ;
    rdfs:domain top:Port ;
    rdfs:range top:Port ;
    owl:inverseOf top:isConnectedPortOf ;
    rdfs:label "connects port"@en ;
    rdfs:comment "Connects two ports without asserting flow direction. This is the preferred direct mapping for port-to-port connectivity such as IfcRelConnectsPorts."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:isConnectedPortOf rdf:type owl:ObjectProperty ;
    rdfs:domain top:Port ;
    rdfs:range top:Port ;
    rdfs:label "is connected port of"@en ;
    rdfs:comment "Inverse or companion relation for top:connectsPort where a directional statement is required by an export process."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:servesSpatialStructure rdf:type owl:ObjectProperty ;
    rdfs:domain top:System, top:Equipment ;
    rdfs:range top:Topology ;
    owl:inverseOf top:isServedBy ;
    rdfs:label "serves spatial structure"@en ;
    rdfs:comment "Associates a system or equipment item with the spatial structure it serves, such as a site, building, storey, space, or zone."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:isServedBy rdf:type owl:ObjectProperty ;
    rdfs:domain top:Topology ;
    rdfs:range top:System, top:Equipment ;
    rdfs:label "is served by"@en ;
    rdfs:comment "Associates a spatial structure with the system or equipment item that serves it."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:servesBuilding rdf:type owl:ObjectProperty ;
    rdfs:domain top:System, top:Equipment ;
    rdfs:range top:Building ;
    rdfs:subPropertyOf top:servesSpatialStructure ;
    rdfs:label "serves building"@en ;
    rdfs:comment "Associates a system or equipment item with a building it serves."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:aggregates rdf:type owl:ObjectProperty ;
    rdfs:domain top:Topology ;
    rdfs:range top:Topology ;
    owl:inverseOf top:isAggregatedBy ;
    rdfs:label "aggregates"@en ;
    rdfs:comment "Represents a whole-part, decomposition, or aggregation relationship, commonly mapped from IFC aggregation or decomposition relations."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:isAggregatedBy rdf:type owl:ObjectProperty ;
    rdfs:domain top:Topology ;
    rdfs:range top:Topology ;
    rdfs:label "is aggregated by"@en ;
    rdfs:comment "Inverse relation of top:aggregates, associating a part with its aggregate or whole."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:isPartOf rdf:type owl:ObjectProperty ;
    rdfs:domain top:Topology ;
    rdfs:range top:Topology ;
    rdfs:subPropertyOf bot:isPartOf ;
    owl:inverseOf top:containsElement ;
    rdfs:label "is part of"@en ;
    rdfs:comment "Associates a topology, element, space, or entity with a containing or aggregating whole."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:containsElement rdf:type owl:ObjectProperty ;
    rdfs:domain top:Topology ;
    rdfs:range top:Topology ;
    rdfs:subPropertyOf bot:containsElement ;
    rdfs:label "contains element"@en ;
    rdfs:comment "Associates a spatial, topological, or semantic container with a contained topology, element, space, or entity."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:hasOpening rdf:type owl:ObjectProperty ;
    rdfs:domain top:Element ;
    rdfs:range top:Opening ;
    owl:inverseOf top:isOpeningIn ;
    rdfs:label "has opening"@en ;
    rdfs:comment "Associates an element with an opening, void, penetration, or recess."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:isOpeningIn rdf:type owl:ObjectProperty ;
    rdfs:domain top:Opening ;
    rdfs:range top:Element ;
    rdfs:label "is opening in"@en ;
    rdfs:comment "Inverse relation of top:hasOpening, associating an opening with its host element."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:fillsOpening rdf:type owl:ObjectProperty ;
    rdfs:domain top:Element ;
    rdfs:range top:Opening ;
    owl:inverseOf top:isFilledBy ;
    rdfs:label "fills opening"@en ;
    rdfs:comment "Associates an element such as a door, window, or service component with the opening it fills."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:isFilledBy rdf:type owl:ObjectProperty ;
    rdfs:domain top:Opening ;
    rdfs:range top:Element ;
    rdfs:label "is filled by"@en ;
    rdfs:comment "Inverse relation of top:fillsOpening, associating an opening with the element that fills it."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:hasPropertySet rdf:type owl:ObjectProperty ;
    rdfs:domain top:Topology, top:System, top:Relationship ;
    rdfs:range top:PropertySet ;
    owl:inverseOf top:isPropertySetOf ;
    rdfs:label "has property set"@en ;
    rdfs:comment "Associates a topology, element, type, system, graph entity, or relationship with a property set."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:isPropertySetOf rdf:type owl:ObjectProperty ;
    rdfs:domain top:PropertySet ;
    rdfs:range top:Topology, top:System, top:Relationship ;
    rdfs:label "is property set of"@en ;
    rdfs:comment "Inverse relation of top:hasPropertySet."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:hasIFCType rdf:type owl:ObjectProperty ;
    rdfs:domain top:Topology ;
    owl:inverseOf top:isIFCTypeOf ;
    rdfs:label "has IFC type"@en ;
    rdfs:comment "Associates an IFC occurrence or mapped topology with its IFC type object."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:isIFCTypeOf rdf:type owl:ObjectProperty ;
    rdfs:range top:Topology ;
    rdfs:label "is IFC type of"@en ;
    rdfs:comment "Inverse relation of top:hasIFCType."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:hasMaterial rdf:type owl:ObjectProperty ;
    rdfs:domain top:Topology ;
    rdfs:range top:Material, top:MaterialSet ;
    owl:inverseOf top:isMaterialOf ;
    rdfs:label "has material"@en ;
    rdfs:comment "Associates a topology, element, or mapped BIM entity with a material or material set."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:isMaterialOf rdf:type owl:ObjectProperty ;
    rdfs:domain top:Material, top:MaterialSet ;
    rdfs:range top:Topology ;
    rdfs:label "is material of"@en ;
    rdfs:comment "Inverse relation of top:hasMaterial."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:hasClassification rdf:type owl:ObjectProperty ;
    rdfs:domain top:Topology ;
    rdfs:range top:ClassificationReference ;
    owl:inverseOf top:isClassificationOf ;
    rdfs:label "has classification"@en ;
    rdfs:comment "Associates a topology, element, system, or mapped BIM entity with a classification reference."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:isClassificationOf rdf:type owl:ObjectProperty ;
    rdfs:domain top:ClassificationReference ;
    rdfs:range top:Topology ;
    rdfs:label "is classification of"@en ;
    rdfs:comment "Inverse relation of top:hasClassification."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:hasDocument rdf:type owl:ObjectProperty ;
    owl:inverseOf top:isDocumentOf ;
    rdfs:label "has document"@en ;
    rdfs:comment "Associates an entity with a document reference, external file, specification, drawing, approval package, or supporting document."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:isDocumentOf rdf:type owl:ObjectProperty ;
    rdfs:label "is document of"@en ;
    rdfs:comment "Inverse relation of top:hasDocument."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:hasApproval rdf:type owl:ObjectProperty ;
    owl:inverseOf top:isApprovalOf ;
    rdfs:label "has approval"@en ;
    rdfs:comment "Associates an entity with an approval, review, authorisation, or sign-off record."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:isApprovalOf rdf:type owl:ObjectProperty ;
    rdfs:label "is approval of"@en ;
    rdfs:comment "Inverse relation of top:hasApproval."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:hasConstraint rdf:type owl:ObjectProperty ;
    owl:inverseOf top:isConstraintOf ;
    rdfs:label "has constraint"@en ;
    rdfs:comment "Associates an entity with a rule, constraint, requirement, limit, or validation condition."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:isConstraintOf rdf:type owl:ObjectProperty ;
    rdfs:label "is constraint of"@en ;
    rdfs:comment "Inverse relation of top:hasConstraint."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:locatedIn rdf:type owl:ObjectProperty ;
    rdfs:domain top:Topology ;
    rdfs:range top:Topology ;
    rdfs:label "located in"@en ;
    rdfs:comment "Associates a topology, element, node, or entity with the containing, nearest, or inferred spatial structure derived by geometric or semantic analysis."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:intersects rdf:type owl:ObjectProperty, owl:SymmetricProperty ;
    rdfs:domain top:Topology ;
    rdfs:range top:Topology ;
    rdfs:label "intersects"@en ;
    rdfs:comment "Associates two topologies, elements, spaces, or regions that geometrically or topologically intersect according to a declared tolerance or spatial predicate."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:passesThrough rdf:type owl:ObjectProperty ;
    rdfs:domain top:Topology ;
    rdfs:range top:Topology ;
    rdfs:label "passes through"@en ;
    rdfs:comment "Indicates that one topology, element, or system component passes through another topology, element, space, or region."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:requiresOpening rdf:type owl:ObjectProperty ;
    rdfs:domain top:Topology ;
    rdfs:range top:Element ;
    rdfs:label "requires opening"@en ;
    rdfs:comment "Indicates that an element, system component, route, or topology requires an opening through another element."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:hasMissingOpening rdf:type owl:ObjectProperty ;
    rdfs:domain top:Topology ;
    rdfs:range top:Element ;
    rdfs:label "has missing opening"@en ;
    rdfs:comment "Associates an element or topology with a coordination issue in which an expected opening is absent."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:violatesCoordinationRule rdf:type owl:ObjectProperty ;
    rdfs:domain top:Topology ;
    rdfs:range top:Relationship ;
    rdfs:label "violates coordination rule"@en ;
    rdfs:comment "Associates an entity with a violated coordination rule, model-checking rule, or relationship record."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:hasCoordinationIssue rdf:type owl:ObjectProperty ;
    rdfs:domain top:Topology ;
    rdfs:range top:Relationship ;
    rdfs:label "has coordination issue"@en ;
    rdfs:comment "Associates an entity with a detected coordination, clash, validation, or quality issue."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:derivedFrom rdf:type owl:ObjectProperty ;
    rdfs:label "derived from"@en ;
    rdfs:comment "Associates an entity, topology, graph, or record with the source entity, model, file, process, or data object from which it was derived."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:generatedBy rdf:type owl:ObjectProperty ;
    rdfs:label "generated by"@en ;
    rdfs:comment "Associates an entity, topology, graph, or record with the method, script, notebook, process, or software operation that generated it."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

# =============================================================================
# Datatype properties and dictionary-derived properties
# =============================================================================

top:category rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "category"@en ;
    rdfs:comment "A broad category value emitted from TopologicPy dictionaries, such as topology, graph, space, element, equipment, interface, project, metadata, mathematics, or analysis."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:relationship rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "relationship"@en ;
    rdfs:comment "A general-purpose relationship label emitted from TopologicPy dictionaries when a more specific ontology predicate is not available."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:ontologyClass rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "ontology class"@en ;
    rdfs:comment "The ontology class QName or URI recorded in a TopologicPy dictionary, commonly stored under the dictionary key ontology_class."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:ontologyURI rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:anyURI ;
    rdfs:label "ontology URI"@en ;
    rdfs:comment "The expanded ontology URI recorded in a TopologicPy dictionary, commonly stored under the dictionary key ontology_uri."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:hasX rdf:type owl:DatatypeProperty ;
    rdfs:domain top:Vertex ;
    rdfs:range xsd:double ;
    rdfs:label "has X"@en ;
    rdfs:comment "The X coordinate of a vertex, point, node, or graph vertex record."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:hasY rdf:type owl:DatatypeProperty ;
    rdfs:domain top:Vertex ;
    rdfs:range xsd:double ;
    rdfs:label "has Y"@en ;
    rdfs:comment "The Y coordinate of a vertex, point, node, or graph vertex record."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:hasZ rdf:type owl:DatatypeProperty ;
    rdfs:domain top:Vertex ;
    rdfs:range xsd:double ;
    rdfs:label "has Z"@en ;
    rdfs:comment "The Z coordinate of a vertex, point, node, or graph vertex record."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:x rdf:type owl:DatatypeProperty ;
    rdfs:domain top:Vertex ;
    rdfs:range xsd:double ;
    owl:equivalentProperty top:hasX ;
    rdfs:label "x"@en ;
    rdfs:comment "Alias data property for the X coordinate when TopologicPy dictionary export emits the raw key x."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:y rdf:type owl:DatatypeProperty ;
    rdfs:domain top:Vertex ;
    rdfs:range xsd:double ;
    owl:equivalentProperty top:hasY ;
    rdfs:label "y"@en ;
    rdfs:comment "Alias data property for the Y coordinate when TopologicPy dictionary export emits the raw key y."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:z rdf:type owl:DatatypeProperty ;
    rdfs:domain top:Vertex ;
    rdfs:range xsd:double ;
    owl:equivalentProperty top:hasZ ;
    rdfs:label "z"@en ;
    rdfs:comment "Alias data property for the Z coordinate when TopologicPy dictionary export emits the raw key z."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:hasLength rdf:type owl:DatatypeProperty ;
    rdfs:domain top:Topology ;
    rdfs:range xsd:double ;
    rdfs:label "has length"@en ;
    rdfs:comment "The length of an edge, wire, path, graph edge, or other length-bearing topology or analytical record."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:hasArea rdf:type owl:DatatypeProperty ;
    rdfs:domain top:Topology ;
    rdfs:range xsd:double ;
    rdfs:label "has area"@en ;
    rdfs:comment "The area of a face, shell, cell, cell complex, surface, spatial region, or other area-bearing topology or analytical record."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:hasVolume rdf:type owl:DatatypeProperty ;
    rdfs:domain top:Topology ;
    rdfs:range xsd:double ;
    rdfs:label "has volume"@en ;
    rdfs:comment "The volume of a cell, cell complex, zone, space, or other volume-bearing topology or analytical record."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:length rdf:type owl:DatatypeProperty ;
    rdfs:domain top:Topology ;
    rdfs:range xsd:double ;
    owl:equivalentProperty top:hasLength ;
    rdfs:label "length"@en ;
    rdfs:comment "Alias data property for length when TopologicPy dictionary export emits the raw key length."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:area rdf:type owl:DatatypeProperty ;
    rdfs:domain top:Topology ;
    rdfs:range xsd:double ;
    owl:equivalentProperty top:hasArea ;
    rdfs:label "area"@en ;
    rdfs:comment "Alias data property for area when TopologicPy dictionary export emits the raw key area."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:volume rdf:type owl:DatatypeProperty ;
    rdfs:domain top:Topology ;
    rdfs:range xsd:double ;
    owl:equivalentProperty top:hasVolume ;
    rdfs:label "volume"@en ;
    rdfs:comment "Alias data property for volume when TopologicPy dictionary export emits the raw key volume."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:hasMantissa rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer ;
    rdfs:label "has mantissa"@en ;
    rdfs:comment "The number of decimal places used to round, serialize, compare, or report numeric values."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:mantissa rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer ;
    owl:equivalentProperty top:hasMantissa ;
    rdfs:label "mantissa"@en ;
    rdfs:comment "Alias data property for mantissa when TopologicPy dictionary export emits the raw key mantissa."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:hasUnit rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "has unit"@en ;
    rdfs:comment "The unit of measurement associated with a value, topology, graph, metric, or record."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:unit rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    owl:equivalentProperty top:hasUnit ;
    rdfs:label "unit"@en ;
    rdfs:comment "Alias data property for unit when TopologicPy dictionary export emits the raw key unit."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:createdAt rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime ;
    rdfs:label "created at"@en ;
    rdfs:comment "The creation timestamp of an entity, topology, graph, or record."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:modifiedAt rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime ;
    rdfs:label "modified at"@en ;
    rdfs:comment "The last modification timestamp of an entity, topology, graph, or record."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:label rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "label"@en ;
    rdfs:comment "A human-readable label emitted from a TopologicPy dictionary when represented as data rather than rdfs:label."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:name rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "name"@en ;
    rdfs:comment "A human-readable name emitted from a TopologicPy dictionary."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:description rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "description"@en ;
    rdfs:comment "A human-readable description emitted from a TopologicPy dictionary."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:ifcClass rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "IFC class"@en ;
    rdfs:comment "The IFC entity class name associated with a topology, graph entity, or record, commonly stored under the dictionary key ifc_class."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:ifcGUID rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "IFC GUID"@en ;
    rdfs:comment "The IFC GlobalId associated with a topology, graph entity, or record, commonly stored under the dictionary key ifc_guid."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

top:source rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "source"@en ;
    rdfs:comment "The source file, model, database, method, or process associated with an entity, topology, graph, or record."@en ;
    rdfs:isDefinedBy <http://w3id.org/topologicpy> .

# =============================================================================
# External vocabulary alignment
# =============================================================================

top:Project skos:closeMatch ifc:IfcProject .
top:Site skos:closeMatch ifc:IfcSite .
top:Building skos:closeMatch ifc:IfcBuilding .
top:Storey skos:closeMatch ifc:IfcBuildingStorey .
top:Space skos:closeMatch ifc:IfcSpace .
top:Zone skos:closeMatch ifc:IfcZone .
top:Wall skos:closeMatch ifc:IfcWall .
top:CurtainWall skos:closeMatch ifc:IfcCurtainWall .
top:Door skos:closeMatch ifc:IfcDoor .
top:Window skos:closeMatch ifc:IfcWindow .
top:Slab skos:closeMatch ifc:IfcSlab .
top:Roof skos:closeMatch ifc:IfcRoof .
top:Column skos:closeMatch ifc:IfcColumn .
top:Beam skos:closeMatch ifc:IfcBeam .
top:Stair skos:closeMatch ifc:IfcStair .
top:Railing skos:closeMatch ifc:IfcRailing .
top:Opening skos:closeMatch ifc:IfcOpeningElement .
top:Furniture skos:closeMatch ifc:IfcFurnishingElement .
top:Equipment skos:closeMatch ifc:IfcDistributionElement .
top:Interface skos:closeMatch ifc:IfcRelSpaceBoundary .
top:PropertySet skos:closeMatch ifc:IfcPropertySet .
top:Quantity skos:closeMatch ifc:IfcElementQuantity .
top:Material skos:closeMatch ifc:IfcMaterial .
top:MaterialSet skos:closeMatch ifc:IfcMaterialLayerSet .
top:ClassificationReference skos:closeMatch ifc:IfcClassificationReference .
